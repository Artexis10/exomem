{
  "artifact": "exomem-hosted-operator-contract",
  "contract_version": 1,
  "binding_version": 2,
  "invocation": {
    "argv_by_command": {
      "init": [
        "exomem",
        "hosted",
        "init",
        "--contract-version",
        "1",
        "--request-file",
        "/run/exomem/operator-requests/init.json"
      ],
      "restore-candidate": [
        "exomem",
        "hosted",
        "restore-candidate",
        "--contract-version",
        "1",
        "--request-file",
        "/run/exomem/operator-requests/restore-candidate.json"
      ],
      "credential": [
        "exomem",
        "hosted",
        "credential",
        "--contract-version",
        "1",
        "--request-file",
        "-"
      ],
      "probe": [
        "exomem",
        "hosted",
        "probe",
        "--contract-version",
        "1",
        "--request-file",
        "-"
      ]
    },
    "commands": [
      "init",
      "restore-candidate",
      "credential",
      "probe"
    ],
    "request_encoding": "utf-8-json-with-no-duplicate-keys",
    "request_max_bytes": 65536,
    "stdout": "exactly-one-canonical-json-line",
    "stdout_max_bytes": 65536,
    "stderr_for_modeled_outcome": "empty",
    "unknown_argument_or_request_field": "HOSTED_OPERATOR_CONTRACT_INVALID"
  },
  "offline_request_file": {
    "commands": [
      "init",
      "restore-candidate"
    ],
    "directory": "/run/exomem/operator-requests",
    "path_by_command": {
      "init": "/run/exomem/operator-requests/init.json",
      "restore-candidate": "/run/exomem/operator-requests/restore-candidate.json"
    },
    "kubernetes_delivery": "one-shot-read-only-subPath-regular-file",
    "container_mount_read_only": true,
    "updates_supported": false,
    "absolute_path_required": true,
    "parent_symlink_components": false,
    "leaf_symlink": false,
    "owner_uid": 0,
    "allowed_modes_octal": [
      "0400",
      "0440",
      "0444"
    ],
    "write_bits": false,
    "regular_file": true,
    "hard_link_count": 1,
    "open_flags": [
      "O_RDONLY",
      "O_CLOEXEC",
      "O_NOFOLLOW"
    ],
    "read_once_from_one_fd": true,
    "fstat_before_and_after_must_match": [
      "device",
      "inode",
      "type",
      "owner_uid",
      "mode",
      "size"
    ],
    "max_bytes": 65536,
    "replacement_after_open": "cannot-change-read-generation"
  },
  "live_request_stdin": {
    "commands": [
      "credential",
      "probe"
    ],
    "request_file_argument": "-",
    "kubernetes_delivery": "authenticated-provisioner-exec-stdin-to-running-exomem-container",
    "shell": false,
    "terminal_or_pty": false,
    "stdin_is_only_request_source": true,
    "stdin_must_reach_eof": true,
    "stdin_trailing_bytes_after_json": "rejected",
    "stdin_max_bytes": 65536,
    "argv_environment_or_persistent_file_request": false,
    "exec_transport_trust_boundary": "authorized-kubernetes-api-exec-principal-and-provisioner-operation",
    "reason": "live commands must execute inside the running cell for current security state and literal-loopback readiness without restarting the pod or mutating its filesystem"
  },
  "formats": {
    "opaque_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,127}$"
    },
    "credential_version": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "uuid_v4": {
      "type": "string",
      "canonical_rfc4122_version": 4
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "absolute_root": {
      "type": "string",
      "max_utf8_bytes": 4096,
      "normalization": "absolute-normalized-no-symlink-components"
    },
    "runtime_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "operation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
    }
  },
  "common_request": {
    "required": [
      "request_id"
    ],
    "properties": {
      "request_id": "uuid_v4"
    }
  },
  "mutating_request": {
    "required": [
      "request_id",
      "operation_id"
    ],
    "properties": {
      "request_id": "uuid_v4",
      "operation_id": "operation_id"
    },
    "idempotency": "operation_id-plus-sha256-of-canonical-complete-request"
  },
  "credential_delivery": {
    "path": "/run/exomem/credentials/credentials.json",
    "path_is_caller_configurable": false,
    "kubernetes_volume": "native-secret-atomic-writer",
    "kubernetes_default_mode_octal": "0444",
    "pod_fs_group": null,
    "mounted_containers_exact": [
      "exomem"
    ],
    "file_owner_uid": 0,
    "file_owner_gid": 0,
    "file_mode_octal": "0444",
    "container_mount_read_only": true,
    "resolved_type": "regular-file",
    "accepted_symlink_topology": "fixed-leaf-to-kubelet-owned-dotdot-data-generation-confined-inside-mount",
    "one_fd_generation_read": true,
    "threat_boundary": "single-process-single-tenant-container; no untrusted sidecar or user process",
