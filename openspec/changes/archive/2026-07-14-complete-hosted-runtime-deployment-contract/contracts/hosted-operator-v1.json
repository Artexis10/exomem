                "restore-candidate",
                "credential",
                "probe"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "request_id": {
          "one_of": [
            "uuid_v4",
            {
              "type": "null"
            }
          ]
        }
      },
      "null_rule": "command or request_id is null only when that field cannot be validated before failure; unvalidated input is never echoed",
      "error_required": [
        "code",
        "message",
        "retryable",
        "operator_action"
      ],
      "error_additional_properties": false
    }
  },
  "exit_status": {
    "0": "success",
    "2": "contract-or-input-invalid",
    "3": "durable-state-or-ownership-conflict",
    "4": "retryable-busy-or-unavailable",
    "5": "archive-or-persistent-integrity-failure",
    "6": "redacted-internal-failure"
  },
  "error_classes": {
    "input": {
      "exit_status": 2,
      "retryable": false,
      "message": "hosted operator request is invalid",
      "operator_action": "fix-request"
    },
    "conflict": {
      "exit_status": 3,
      "retryable": false,
      "message": "hosted operator state conflicts with the request",
      "operator_action": "inspect-content-free-state"
    },
    "unavailable": {
      "exit_status": 4,
      "retryable": true,
      "message": "hosted operator dependency is temporarily unavailable",
      "operator_action": "retry-with-the-same-request"
    },
    "integrity": {
      "exit_status": 5,
      "retryable": false,
      "message": "hosted data integrity verification failed",
      "operator_action": "quarantine-and-investigate"
    },
    "internal": {
      "exit_status": 6,
      "retryable": false,
      "message": "hosted operator failed safely",
      "operator_action": "inspect-redacted-operator-logs"
    }
  },
