# exomem — environment configuration template.
#
# Copy to `.env` and fill in:  cp env.example .env
# `.env` is gitignored; this template is the ONE complete reference for every
# variable exomem reads. Not every var is needed for every mode — each block
# says which. `exomem setup` (local) and `exomem setup --remote` write the
# blocks they own for you; this file documents the rest.
#
#   Local Claude Code (stdio)   -> only EXOMEM_VAULT_PATH.
#   Remote connector (claude.ai / iOS) -> also the "Remote / GitHub OAuth" block.
#   Docker/tunnel deployment    -> also the "Tunnel + Docker" block.

# ---------------------------------------------------------------------------
# Core — required in every mode
# ---------------------------------------------------------------------------

# Absolute path to your Obsidian vault ROOT — the folder that CONTAINS
# "Knowledge Base/" (not the Knowledge Base folder itself). Required for every
# mode: claude.ai connects over HTTP and passes no environment of its own, so
# the remote service resolves the vault solely from here at startup.
EXOMEM_VAULT_PATH=/path/to/your/Obsidian

# ---------------------------------------------------------------------------
# Search profile — optional
# ---------------------------------------------------------------------------

# Set to 1 for a lean, keyword/BM25-only install (no embeddings, no torch).
# Leave unset for hybrid semantic search (needs `uv sync --extra embeddings`).
# EXOMEM_DISABLE_EMBEDDINGS=1

# Path to the Tesseract OCR binary if it is not on PATH (media profile only).
# EXOMEM_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ---------------------------------------------------------------------------
# HTTP transport bind — optional (remote / service use)
# ---------------------------------------------------------------------------

# Bind address for the http transport. Default 127.0.0.1 (fronted by a tunnel).
# Set 0.0.0.0 to also serve a direct LAN / Tailscale route.
# EXOMEM_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Remote connector / GitHub OAuth — required for claude.ai + iOS access
# ---------------------------------------------------------------------------
# `exomem setup --remote` writes this whole block. See docs/remote-quickstart.md.

# Public HTTPS origin the connector reaches. NO trailing slash, NO /mcp suffix.
#   e.g. https://kb.example.com   or   https://you.ngrok-free.dev
EXOMEM_BASE_URL=https://your-host.example.com

# GitHub OAuth App (github.com/settings/developers -> OAuth Apps -> New OAuth App).
# The Authorization callback URL must be exactly  https://<host>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The single GitHub login allowed to authenticate to this connector.
EXOMEM_GITHUB_USERNAME=

# Stable JWT signing key — pins the OAuth token store so connector re-auth does
# NOT recur on client-secret rotation or FastMCP upgrades. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
EXOMEM_JWT_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Remote extras — optional
# ---------------------------------------------------------------------------

# Bearer key for the personal REST facade (/api/<tool>). Generate:
#   uv run --no-sync python scripts/set-rest-key.py
# EXOMEM_REST_API_KEY=

# Secret that enables binary upload/download token minting. Generate:
#   uv run python scripts/set-upload-token.py
# EXOMEM_UPLOAD_TOKEN=

# ---------------------------------------------------------------------------
# Tunnel + Docker — compose deployment only (see compose.yaml / docs/docker.md)
# ---------------------------------------------------------------------------

# HOST path bind-mounted to /vault in the container. The compose stack sets the
# container's own EXOMEM_VAULT_PATH=/vault, so this is the host side of that mount.
# EXOMEM_VAULT_HOST_PATH=/path/to/your/Obsidian

# ngrok  (docker compose --profile ngrok, or scripts/setup-ngrok.ps1):
#   NGROK_DOMAIN is your free static dev domain; NGROK_AUTHTOKEN from the dashboard.
# NGROK_AUTHTOKEN=
# NGROK_DOMAIN=you.ngrok-free.dev

# Cloudflare Tunnel  (docker compose --profile cloudflared):
# CLOUDFLARE_TUNNEL_TOKEN=
