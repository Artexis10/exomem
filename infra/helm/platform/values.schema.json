{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "runtime": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "pattern": "^[^\\s]+@sha256:[a-f0-9]{64}$"
        }
      }
    },
    "admission": {
      "type": "object",
      "required": ["namespaceContractOperatorUsernames"],
      "properties": {
        "namespaceContractOperatorUsernames": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
